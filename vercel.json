{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "public/**,views/**,middleware/**,routes/**,models/**,utils/**,config/**,functions/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
